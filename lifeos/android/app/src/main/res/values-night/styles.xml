<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- LifeOS is dark-first by design (docs/07_Design_System.md) — the
         night variant is identical to the default theme rather than
         inverting to a light background. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/lifeos_background</item>
    </style>
</resources>
